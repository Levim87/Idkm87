                local function closeDropdown()
                    if currentPopup and currentPopup.Parent then
                        currentPopup:Destroy()
                        currentPopup = nil
                    end
                    dropdownOpen = false
                end

                local function openDropdown()
                    if dropdownOpen then
                        closeDropdown()
                        return
                    end
                    dropdownOpen = true
                    local popupFrame = createDropdownPopup(nil, btn, options, function(val)
                        selected = val
                        btn.Text = val
                        callback(val)
                        closeDropdown()
                    end, false, selected)
                    local _, closeFunc = NeonUI:CreatePopup(function(parent)
                        popupFrame.Parent = parent
                        return popupFrame
                    end, btn, 0, 2, function()
                        dropdownOpen = false
                        currentPopup = nil
                    end)
                    currentPopup = popupFrame
                end

                btn.MouseButton1Click:Connect(openDropdown)
                btn.TouchTap:Connect(openDropdown)

                return {
                    SetOptions = function(newOpts)
                        options = newOpts
                        if not table.find(options, selected) then
                            selected = options[1]
                            btn.Text = selected
                            callback(selected)
                        end
                    end,
                    SetValue = function(val)
                        selected = val
                        btn.Text = val
                        callback(val)
                    end,
                    GetValue = function() return selected end
                }
            end

