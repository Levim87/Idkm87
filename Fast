            dragStartMouse = UserInputService:GetMouseLocation()
            dragStartPos = Main.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if draggingWindow and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = UserInputService:GetMouseLocation() - dragStartMouse
            Main.Position = UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + delta.X, dragStartPos.Y.Scale, dragStartPos.Y.Offset + delta.Y)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingWindow = false
        end
    end)

    if ResizeHandle then
        local resizing = false
        local resizeStartPos = nil
        local resizeStartSize = nil

        ResizeHandle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = true
                resizeStartPos = UserInputService:GetMouseLocation()
                resizeStartSize = Main.AbsoluteSize
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = UserInputService:GetMouseLocation() - resizeStartPos
                local newWidth = math.max(WindowManager.MinWindowSize.X, resizeStartSize.X + delta.X)
                local newHeight = math.max(WindowManager.MinWindowSize.Y, resizeStartSize.Y + delta.Y)
                Main.Size = UDim2.new(0, newWidth, 0, newHeight)
                if not Window.Minimized then
                    Window.OriginalSize = Vector2.new(newWidth, newHeight)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = false
            end
        end)
    end

    table.insert(WindowManager.Windows, Window)
    return Window
end

function NeonUI:SetTheme(themeName)
    if self.Themes[themeName] then
        self.ActiveTheme = themeName
        for _, window in ipairs(WindowManager.Windows) do
            window:SetTheme(themeName)
        end
    end
end

function NeonUI:GetTheme()
    return GetTheme()
end

function NeonUI:NotificationPosition(position)
    if position and (position == "TopLeft" or position == "TopRight" or position == "BottomLeft" or position == "BottomRight") then
        self.NotificationPosition = position
    end
    return self.NotificationPosition
end

NeonUI.GlobalPopupLayer = NeonUI:GetPopupLayer()

return NeonUI
