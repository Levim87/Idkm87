function NeonUI:Notify(title, text, notificationType, duration)
    notificationType = notificationType or "info"
    duration = duration or self.NotificationLifetime or 4

    local icon, color
    if notificationType == "success" then
        icon = ASSETS.Checkmark
        color = GetTheme().Success
    elseif notificationType == "error" then
        icon = ASSETS.Error
        color = GetTheme().Error
    elseif notificationType == "warning" then
        icon = ASSETS.Warning
        color = GetTheme().Warning
    else
        icon = ASSETS.Info
        color = GetTheme().Accent
    end

    local container = getNotificationContainer(self.NotificationPosition)
    local notification, closeBtn, progressBar = createNotificationUI(title, text, icon, duration, color)

    notification.Parent = container
    notification.Position = UDim2.new(0, 0, 1, 0)
    notification:TweenPosition(UDim2.new(0, 0, 1, -notification.AbsoluteSize.Y - 8), "Out", "Quad", 0.3)

    local startTime = tick()
    local connection
    local function updateProgress()
        local elapsed = tick() - startTime
        local percent = math.max(0, 1 - (elapsed / duration))
        progressBar.Size = UDim2.new(percent, 0, 1, 0)
        if percent <= 0 then
            if connection then connection:Disconnect() end
            notification:TweenPosition(UDim2.new(0, 0, 1, 0), "In", "Quad", 0.3)
            task.delay(0.3, function()
                if notification and notification.Parent then notification:Destroy() end
            end)
        end
    end

    connection = RunService.RenderStepped:Connect(updateProgress)
    closeBtn.MouseButton1Click:Connect(function()
        if connection then connection:Disconnect() end
        notification:TweenPosition(UDim2.new(0, 0, 1, 0), "In", "Quad", 0.3)
        task.delay(0.3, function()
            if notification and notification.Parent then notification:Destroy() end
        end)
    end)

    notification.MouseEnter:Connect(function()
        if connection then connection:Disconnect() end
    end)

    notification.MouseLeave:Connect(function()
        startTime = tick() - (duration * (1 - (progressBar.Size.X.Scale)))
        connection = RunService.RenderStepped:Connect(updateProgress)
    end)

    return notification
end

