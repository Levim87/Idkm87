function NeonUI:CreatePopup(contentBuilder, anchorFrame, offsetX, offsetY, onClose)
    local layer = self:GetPopupLayer()
    local popupFrame = Instance.new("Frame")
    popupFrame.Size = UDim2.new(0, 0, 0, 0)
    popupFrame.BackgroundTransparency = 1
    popupFrame.ZIndex = PopupManager.ZIndexCounter
    popupFrame.Parent = layer

    PopupManager.ZIndexCounter = PopupManager.ZIndexCounter + 1

    local content = contentBuilder(popupFrame)
    popupFrame.Size = UDim2.new(0, content.AbsoluteSize.X, 0, content.AbsoluteSize.Y)
    content.Parent = popupFrame

    local anchorAbsPos = anchorFrame.AbsolutePosition
    local anchorAbsSize = anchorFrame.AbsoluteSize
    local screenSize = Camera.ViewportSize

    local targetX = anchorAbsPos.X + (offsetX or 0)
    local targetY = anchorAbsPos.Y + anchorAbsSize.Y + (offsetY or 5)

    if targetX + popupFrame.AbsoluteSize.X > screenSize.X then
        targetX = screenSize.X - popupFrame.AbsoluteSize.X - 10
    end
    if targetX < 10 then targetX = 10 end

    if targetY + popupFrame.AbsoluteSize.Y > screenSize.Y then
        targetY = anchorAbsPos.Y - popupFrame.AbsoluteSize.Y - (offsetY or 5)
    end
    if targetY < 10 then targetY = 10 end

    popupFrame.Position = UDim2.new(0, targetX, 0, targetY)

    local closeConnection
    local function closePopup()
        if closeConnection then closeConnection:Disconnect() end
        if onClose then onClose() end
        popupFrame:Destroy()
    end

    local function handleClickOutside(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local mousePos = UserInputService:GetMouseLocation()
            if not isInBounds(mousePos, popupFrame) then
                closePopup()
            end
        end
    end

    closeConnection = UserInputService.InputBegan:Connect(handleClickOutside)
    table.insert(PopupManager.ActivePopups, popupFrame)

    popupFrame.AncestryChanged:Connect(function()
        if not popupFrame.Parent then
            if closeConnection then closeConnection:Disconnect() end
            for i, p in ipairs(PopupManager.ActivePopups) do
                if p == popupFrame then table.remove(PopupManager.ActivePopups, i) break end
            end
        end
    end)

    return popupFrame, closePopup
end

