                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = frame

                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(0.65, -4, 0, 32)
                btn.Position = UDim2.new(0.35, 4, 0.5, -16)
                btn.BackgroundColor3 = activeTheme.DropdownBG
                btn.Text = default or options[1] or ""
                btn.TextColor3 = activeTheme.Text
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 13
                btn.BorderSizePixel = 0
                addCorner(btn, 5)
                btn.Parent = frame

                -- Dropdown list will be placed in PopupContainer when open
                local dropdownList = Instance.new("Frame")
                dropdownList.Size = UDim2.new(0, 0, 0, 0)
                dropdownList.BackgroundColor3 = activeTheme.DropdownBG
                dropdownList.BorderSizePixel = 0
                dropdownList.ClipsDescendants = true
                dropdownList.ZIndex = 600
                addCorner(dropdownList, 5)

                local listLayout = Instance.new("UIListLayout")
                listLayout.SortOrder = Enum.SortOrder.LayoutOrder
                listLayout.Parent = dropdownList

                local selected = default or options[1]
                local optionButtons = {}
                local open = false

                local function closeList()
                    if not open then return end
                    open = false
                    dropdownList.Parent = nil
                end

                local function rebuildOptions()
                    for _, b in ipairs(optionButtons) do b:Destroy() end
                    optionButtons = {}
                    for i, opt in ipairs(options) do
                        local optBtn = Instance.new("TextButton")
                        optBtn.Size = UDim2.new(1, 0, 0, 28)
                        optBtn.BackgroundColor3 = activeTheme.DropdownOption
                        optBtn.Text = opt
                        optBtn.TextColor3 = activeTheme.Text
                        optBtn.Font = Enum.Font.Gotham
                        optBtn.TextSize = 13
                        optBtn.BorderSizePixel = 0
                        optBtn.ZIndex = 601
                        optBtn.Parent = dropdownList
                        optBtn.MouseButton1Click:Connect(function()
                            selected = opt
                            btn.Text = opt
                            callback(opt)
                            closeList()
                        end)
                        optBtn.TouchTap:Connect(function()
                            selected = opt
                            btn.Text = opt
                            callback(opt)
                            closeList()
                        end)
                        table.insert(optionButtons, optBtn)
                    end
                end
                rebuildOptions()

                local function openList()
                    if open then return end
                    open = true
                    dropdownList.Parent = Window.PopupContainer
                    -- Position absolutely
                    local btnAbsPos = btn.AbsolutePosition
                    local btnAbsSize = btn.AbsoluteSize
                    dropdownList.Position = UDim2.new(0, btnAbsPos.X, 0, btnAbsPos.Y + btnAbsSize.Y)
                    local targetHeight = math.min(#options * 28, 150)
                    dropdownList.Size = UDim2.new(0, btnAbsSize.X, 0, targetHeight)
                end

                btn.MouseButton1Click:Connect(function()
                    if open then closeList() else openList() end
                end)
                btn.TouchTap:Connect(function()
                    if open then closeList() else openList() end
                end)

                -- Close when clicking outside
                local function onInputBegan(input)
                    if open and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                        local mousePos = UserInputService:GetMouseLocation()
                        local listAbsPos = dropdownList.AbsolutePosition
                        local listAbsSize = dropdownList.AbsoluteSize
                        if mousePos.X < listAbsPos.X or mousePos.X > listAbsPos.X + listAbsSize.X
                            or mousePos.Y < listAbsPos.Y or mousePos.Y > listAbsPos.Y + listAbsSize.Y then
                            closeList()
                        end
                    end
                end
                UserInputService.InputBegan:Connect(onInputBegan)

                return {
                    SetOptions = function(newOpts) options = newOpts; rebuildOptions() end,
                    SetValue = function(val) selected = val; btn.Text = val end,
                }
            end

            -- MULTI-DROPDOWN (Checkbox selection) with ZIndex overlay
            function sectionObj:MultiDropdown(text, options, defaultSelected, callback)
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, 0, 0, 34)
                frame.BackgroundTransparency = 1
                frame.Parent = sectionContent

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(0.35, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = activeTheme.Text
                label.Font = Enum.Font.Gotham
                label.TextSize = 14
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = frame

                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(0.65, -4, 0, 32)
                btn.Position = UDim2.new(0.35, 4, 0.5, -16)
                btn.BackgroundColor3 = activeTheme.DropdownBG
                btn.Text = defaultSelected and #defaultSelected > 0 and table.concat(defaultSelected, ", ") or "None"
                btn.TextColor3 = activeTheme.Text
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 13
                btn.BorderSizePixel = 0
                btn.TextTruncate = Enum.TextTruncate.AtEnd
                addCorner(btn, 5)
                btn.Parent = frame

                local dropdownList = Instance.new("Frame")
                dropdownList.Size = UDim2.new(0, 0, 0, 0)
                dropdownList.BackgroundColor3 = activeTheme.DropdownBG
                dropdownList.BorderSizePixel = 0
                dropdownList.ClipsDescendants = true
                dropdownList.ZIndex = 600
                addCorner(dropdownList, 5)

                local listLayout = Instance.new("UIListLayout")
                listLayout.SortOrder = Enum.SortOrder.LayoutOrder
                listLayout.Parent = dropdownList

                local selectedSet = {}
                for _, v in ipairs(defaultSelected or {}) do selectedSet[v] = true end
                local optionFrames = {}
                local open = false

                local function closeList()
                    if not open then return end
                    open = false
                    dropdownList.Parent = nil
                end

                local function updateButtonText()
                    local selectedList = {}
                    for opt, val in pairs(selectedSet) do if val then table.insert(selectedList, opt) end end
                    btn.Text = #selectedList > 0 and table.concat(selectedList, ", ") or "None"
                end

                local function rebuildOptions()
                    for _, f in ipairs(optionFrames) do f:Destroy() end
                    optionFrames = {}
                    for i, opt in ipairs(options) do
                        local optFrame = Instance.new("Frame")
                        optFrame.Size = UDim2.new(1, 0, 0, 28)
                        optFrame.BackgroundTransparency = 1
                        optFrame.Parent = dropdownList

                        local checkBox = Instance.new("Frame")
                        checkBox.Size = UDim2.new(0, 18, 0, 18)
                        checkBox.Position = UDim2.new(0, 6, 0.5, -9)
                        checkBox.BackgroundColor3 = activeTheme.CheckboxBG
                        checkBox.BorderSizePixel = 0
                        addCorner(checkBox, 3)
                        checkBox.Parent = optFrame

                        local check = Instance.new("ImageLabel")
                        check.Size = UDim2.new(0.8, 0, 0.8, 0)
                        check.AnchorPoint = Vector2.new(0.5, 0.5)
                        check.Position = UDim2.new(0.5, 0, 0.5, 0)
                        check.BackgroundTransparency = 1
                        check.Image = ASSETS.Circle
                        check.ImageColor3 = activeTheme.CheckboxCheck
                        check.Visible = selectedSet[opt] or false
                        check.Parent = checkBox

                        local optText = Instance.new("TextLabel")
                        optText.Size = UDim2.new(1, -30, 1, 0)
                        optText.Position = UDim2.new(0, 28, 0, 0)
                        optText.BackgroundTransparency = 1
                        optText.Text = opt
                        optText.TextColor3 = activeTheme.Text
                        optText.Font = Enum.Font.Gotham
                        optText.TextSize = 13
                        optText.TextXAlignment = Enum.TextXAlignment.Left
                        optText.Parent = optFrame

                        local function toggle()
                            selectedSet[opt] = not selectedSet[opt]
                            check.Visible = selectedSet[opt]
                            updateButtonText()
                            local currentSelected = {}
                            for o, v in pairs(selectedSet) do if v then table.insert(currentSelected, o) end end
                            callback(currentSelected)
                        end

                        optFrame.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                                toggle()
                            end
                        end)
                        checkBox.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                                toggle()
                            end
                        end)
                        table.insert(optionFrames, optFrame)
                    end
                end
                rebuildOptions()
                updateButtonText()

                local function openList()
                    if open then return end
                    open = true
                    dropdownList.Parent = Window.PopupContainer
                    local btnAbsPos = btn.AbsolutePosition
                    local btnAbsSize = btn.AbsoluteSize
                    dropdownList.Position = UDim2.new(0, btnAbsPos.X, 0, btnAbsPos.Y + btnAbsSize.Y)
                    local targetHeight = math.min(#options * 28, 150)
                    dropdownList.Size = UDim2.new(0, btnAbsSize.X, 0, targetHeight)
                end

                btn.MouseButton1Click:Connect(function()
                    if open then closeList() else openList() end
                end)
                btn.TouchTap:Connect(function()
                    if open then closeList() else openList() end
                end)

                local function onInputBegan(input)
                    if open and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                        local mousePos = UserInputService:GetMouseLocation()
                        local listAbsPos = dropdownList.AbsolutePosition
                        local listAbsSize = dropdownList.AbsoluteSize
                        if mousePos.X < listAbsPos.X or mousePos.X > listAbsPos.X + listAbsSize.X
                            or mousePos.Y < listAbsPos.Y or mousePos.Y > listAbsPos.Y + listAbsSize.Y then
                            closeList()
                        end
                    end
                end
                UserInputService.InputBegan:Connect(onInputBegan)

                return {
                    SetSelected = function(sel) selectedSet = {}; for _,v in ipairs(sel) do selectedSet[v]=true end; updateButtonText(); rebuildOptions() end,
                    GetSelected = function() local res={}; for o,v in pairs(selectedSet) do if v then table.insert(res,o) end end; return res end
                }
            end

            -- TEXTBOX
            function sectionObj:Textbox(text, default, callback)
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, 0, 0, 34)
                frame.BackgroundTransparency = 1
                frame.Parent = sectionContent

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(0.35, 0, 1, 0)
