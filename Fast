local DropdownManager = {}
DropdownManager.ActiveDropdowns = {}

local function createDropdownPopup(parentFrame, anchorButton, options, onSelect, multiSelect, defaultSelected)
    local theme = GetTheme()
    local maxHeight = 200
    local itemHeight = 32
    local visibleItems = math.min(#options, 6)
    local dropdownHeight = math.min(#options * itemHeight + 8, maxHeight)

    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.BackgroundColor3 = theme.DropdownBG
    dropdownFrame.BorderSizePixel = 0
    dropdownFrame.ClipsDescendants = true
    addCorner(dropdownFrame, 8)
    addStroke(dropdownFrame, theme.Border, 1)

    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, 0, 1, -8)
    scrollFrame.Position = UDim2.new(0, 0, 0, 4)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.ScrollBarThickness = 4
    scrollFrame.ScrollBarImageColor3 = theme.Accent
    scrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, #options * itemHeight)
    scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.None
    scrollFrame.Parent = dropdownFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 2)
    listLayout.Parent = scrollFrame

    local selectedValues = {}
    if multiSelect and defaultSelected then
        for _, v in ipairs(defaultSelected) do selectedValues[v] = true end
    elseif not multiSelect and defaultSelected then
        selectedValues[defaultSelected] = true
    end

    local optionButtons = {}

    local function updateSelectionVisuals()
        for _, btnData in ipairs(optionButtons) do
            local opt = btnData.option
            if multiSelect then
                if selectedValues[opt] then
                    btnData.button.BackgroundColor3 = theme.DropdownHover
                    if btnData.checkIcon then btnData.checkIcon.Visible = true end
                else
                    btnData.button.BackgroundColor3 = theme.DropdownOption
                    if btnData.checkIcon then btnData.checkIcon.Visible = false end
                end
            else
                if selectedValues[opt] then
                    btnData.button.BackgroundColor3 = theme.Accent
                    btnData.button.TextColor3 = Color3.fromRGB(255, 255, 255)
                else
                    btnData.button.BackgroundColor3 = theme.DropdownOption
                    btnData.button.TextColor3 = theme.Text
                end
            end
        end
    end

    local function getSelectedList()
        local selected = {}
        for opt, val in pairs(selectedValues) do
            if val then table.insert(selected, opt) end
        end
        return selected
    end

    for i, option in ipairs(options) do
        local btnFrame = Instance.new("Frame")
        btnFrame.Size = UDim2.new(1, -8, 0, itemHeight - 2)
        btnFrame.BackgroundTransparency = 1
        btnFrame.Parent = scrollFrame

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 1, 0)
        btn.BackgroundColor3 = theme.DropdownOption
        btn.Text = "  " .. option
        btn.TextColor3 = theme.Text
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 13
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.BorderSizePixel = 0
        addCorner(btn, 5)
        btn.Parent = btnFrame

        local checkIcon
        if multiSelect then
            checkIcon = Instance.new("ImageLabel")
            checkIcon.Size = UDim2.new(0, 16, 0, 16)
            checkIcon.Position = UDim2.new(1, -22, 0.5, -8)
            checkIcon.BackgroundTransparency = 1
            checkIcon.Image = ASSETS.Checkmark
            checkIcon.ImageColor3 = theme.CheckboxCheck
            checkIcon.Visible = selectedValues[option] or false
            checkIcon.Parent = btn
        end

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = theme.DropdownHover}):Play()
        end)
        btn.MouseLeave:Connect(function()
            if not (multiSelect and selectedValues[option]) and not (not multiSelect and selectedValues[option]) then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = theme.DropdownOption}):Play()
            elseif multiSelect and selectedValues[option] then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = theme.DropdownHover}):Play()
            end
        end)

        btn.MouseButton1Click:Connect(function()
            if multiSelect then
                selectedValues[option] = not selectedValues[option]
                onSelect(getSelectedList())
                updateSelectionVisuals()
            else
                for k in pairs(selectedValues) do selectedValues[k] = false end
                selectedValues[option] = true
                onSelect(option)
                updateSelectionVisuals()
                if dropdownFrame.Parent then
                    task.wait(0.05)
                    if dropdownFrame and dropdownFrame.Parent then dropdownFrame:Destroy() end
                end
            end
        end)

        table.insert(optionButtons, {button = btn, option = option, checkIcon = checkIcon})
    end

    updateSelectionVisuals()

    local function updateCanvas()
        local contentHeight = listLayout.AbsoluteContentSize.Y
        if contentHeight > maxHeight then
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
            scrollFrame.ScrollBarThickness = 4
        else
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
            scrollFrame.ScrollBarThickness = 0
        end
    end

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
    task.defer(updateCanvas)

    return dropdownFrame
end

