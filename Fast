            -- COLORPICKER with popup overlay
            function sectionObj:Colorpicker(text, default, callback)
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, 0, 0, 34)
                frame.BackgroundTransparency = 1
                frame.Parent = sectionContent

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(0.35, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = activeTheme.Text
                label.Font = Enum.Font.Gotham
                label.TextSize = 14
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = frame

                local preview = Instance.new("Frame")
                preview.Size = UDim2.new(0.65, -4, 0, 32)
                preview.Position = UDim2.new(0.35, 4, 0.5, -16)
                preview.BackgroundColor3 = default
                preview.BorderSizePixel = 0
                addCorner(preview, 5)
                preview.Parent = frame

                local pickerFrame = Instance.new("Frame")
                pickerFrame.Size = UDim2.new(0, 0, 0, 0)
                pickerFrame.BackgroundColor3 = activeTheme.Element
                pickerFrame.BorderSizePixel = 0
                pickerFrame.ClipsDescendants = true
                pickerFrame.ZIndex = 600
                addCorner(pickerFrame, 7)

                local pickerContent = Instance.new("Frame")
                pickerContent.Size = UDim2.new(1, -16, 1, -16)
                pickerContent.Position = UDim2.new(0, 8, 0, 8)
                pickerContent.BackgroundTransparency = 1
                pickerContent.Parent = pickerFrame

                -- Sat/Val canvas
                local satVal = Instance.new("ImageButton")
                satVal.Size = UDim2.new(1, 0, 0, 140)
                satVal.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                satVal.Image = "rbxassetid://4155801252"
                satVal.AutoButtonColor = false
                satVal.BorderSizePixel = 0
                addCorner(satVal, 4)
                satVal.Parent = pickerContent

                -- Hue slider
                local hueFrame = Instance.new("Frame")
                hueFrame.Size = UDim2.new(1, 0, 0, 14)
                hueFrame.Position = UDim2.new(0, 0, 0, 148)
                hueFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                hueFrame.BorderSizePixel = 0
                addCorner(hueFrame, 7)
                local hueGradient = Instance.new("UIGradient")
                hueGradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0)),
                })
                hueGradient.Parent = hueFrame
                hueFrame.Parent = pickerContent

                local h, s, v = Color3.toHSV(default)
                local currentColor = default
                local currentHue, currentSat, currentVal = h, s, v
                local expanded = false

                local function updateColor()
                    currentColor = Color3.fromHSV(currentHue, currentSat, currentVal)
                    preview.BackgroundColor3 = currentColor
                    callback(currentColor)
                end

                local satValDragging = false
                satVal.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        satValDragging = true
                        local function move()
                            local mousePos = UserInputService:GetMouseLocation()
                            local absPos = satVal.AbsolutePosition
                            local absSize = satVal.AbsoluteSize
                            local relX = math.clamp((mousePos.X - absPos.X) / absSize.X, 0, 1)
                            local relY = math.clamp((mousePos.Y - absPos.Y) / absSize.Y, 0, 1)
                            currentSat = relX
                            currentVal = 1 - relY
                            updateColor()
                        end
                        move()
                        local conn
                        conn = UserInputService.InputChanged:Connect(function(inp)
                            if satValDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                                move()
                            end
                        end)
                        UserInputService.InputEnded:Connect(function(inp)
                            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                                satValDragging = false
                                if conn then conn:Disconnect() end
                            end
                        end)
                    end
                end)

                local hueDragging = false
                hueFrame.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        hueDragging = true
                        local function move()
                            local mousePos = UserInputService:GetMouseLocation()
                            local absPos = hueFrame.AbsolutePosition
                            local absSize = hueFrame.AbsoluteSize
                            local relX = math.clamp((mousePos.X - absPos.X) / absSize.X, 0, 1)
                            currentHue = relX
                            updateColor()
                        end
                        move()
                        local conn
                        conn = UserInputService.InputChanged:Connect(function(inp)
                            if hueDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                                move()
                            end
                        end)
                        UserInputService.InputEnded:Connect(function(inp)
                            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                                hueDragging = false
                                if conn then conn:Disconnect() end
                            end
                        end)
                    end
                end)

                local function openPicker()
                    if expanded then return end
                    expanded = true
                    pickerFrame.Parent = Window.PopupContainer
                    local previewAbsPos = preview.AbsolutePosition
                    local previewAbsSize = preview.AbsoluteSize
                    pickerFrame.Position = UDim2.new(0, previewAbsPos.X, 0, previewAbsPos.Y + previewAbsSize.Y)
                    pickerFrame.Size = UDim2.new(0, previewAbsSize.X, 0, 0)
                    TweenService:Create(pickerFrame, TweenInfo.new(0.2), {Size = UDim2.new(0, previewAbsSize.X, 0, 190)}):Play()
                end

                local function closePicker()
                    if not expanded then return end
                    expanded = false
                    TweenService:Create(pickerFrame, TweenInfo.new(0.2), {Size = UDim2.new(0, pickerFrame.AbsoluteSize.X, 0, 0)}):Play()
                    delay(0.2, function() pickerFrame.Parent = nil end)
                end

                preview.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        if expanded then closePicker() else openPicker() end
                    end
                end)

                local function onInputBegan(input)
                    if expanded and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                        local mousePos = UserInputService:GetMouseLocation()
                        local pickerAbs = pickerFrame.AbsolutePosition
                        local pickerSize = pickerFrame.AbsoluteSize
                        if mousePos.X < pickerAbs.X or mousePos.X > pickerAbs.X + pickerSize.X
                            or mousePos.Y < pickerAbs.Y or mousePos.Y > pickerAbs.Y + pickerSize.Y then
                            closePicker()
                        end
                    end
                end
                UserInputService.InputBegan:Connect(onInputBegan)

                return {
                    SetColor = function(col)
                        currentColor = col
                        h, s, v = Color3.toHSV(col)
                        currentHue, currentSat, currentVal = h, s, v
                        updateColor()
                    end
                }
            end

            -- LABEL
            function sectionObj:Label(text)
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 0, 22)
                lbl.BackgroundTransparency = 1
                lbl.Text = text
                lbl.TextColor3 = activeTheme.Text
                lbl.Font = Enum.Font.Gotham
                lbl.TextSize = 14
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = sectionContent
                return lbl
            end

            -- KEYBIND
            function sectionObj:Keybind(text, defaultKey, callback)
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, 0, 0, 34)
                frame.BackgroundTransparency = 1
                frame.Parent = sectionContent

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(0.35, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = text
                label.TextColor3 = activeTheme.Text
                label.Font = Enum.Font.Gotham
                label.TextSize = 14
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Parent = frame

                local keyBtn = Instance.new("TextButton")
                keyBtn.Size = UDim2.new(0.65, -4, 0, 32)
                keyBtn.Position = UDim2.new(0.35, 4, 0.5, -16)
                keyBtn.BackgroundColor3 = activeTheme.KeybindBG
                keyBtn.Text = defaultKey.Name
                keyBtn.TextColor3 = activeTheme.Text
                keyBtn.Font = Enum.Font.Gotham
                keyBtn.TextSize = 13
                keyBtn.BorderSizePixel = 0
                addCorner(keyBtn, 5)
                keyBtn.Parent = frame

                local currentKey = defaultKey
                local listening = false
                local function startListening()
                    listening = true
                    keyBtn.Text = "..."
                    local conn
                    conn = UserInputService.InputBegan:Connect(function(input)
                        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                            listening = false
                            currentKey = input.KeyCode
                            keyBtn.Text = input.KeyCode.Name
                            conn:Disconnect()
                            callback(input.KeyCode)
                        end
                    end)
                end
                keyBtn.MouseButton1Click:Connect(startListening)
                keyBtn.TouchTap:Connect(startListening)
                return {SetKey = function(key) currentKey = key; keyBtn.Text = key.Name end}
            end

            table.insert(tabObj.Sections, sectionObj)
            return sectionObj
        end

        table.insert(Window.Tabs, tabObj)
        if #Window.Tabs == 1 then
            Window:SelectTab(tabObj)
        end
        return tabObj
    end

    function Window:SelectTab(tab)
        for _, t in ipairs(Window.Tabs) do
            t.Content.Visible = false
            t.Button.BackgroundColor3 = activeTheme.Tab
        end
        tab.Content.Visible = true
        tab.Button.BackgroundColor3 = activeTheme.Accent
        Window.SelectedTab = tab
    end

    -- Window dragging (mouse & touch)
    local dragging = false
    local dragStart, startPos
    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = UserInputService:GetMouseLocation()
            startPos = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = UserInputService:GetMouseLocation() - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return Window
end

-- ================== THEME CHANGER ==================
function NeonUI:SetTheme(themeName)
    if self.Themes[themeName] then
        self.ActiveTheme = themeName
        -- Update all existing windows (simplified: we just set active theme, new windows use it)
        -- For full dynamic update, you'd need to track all created elements and modify them.
    end
end

return NeonUI
