local function getNotificationContainer(position)
    if not NotificationManager.Containers[position] then
        local container = Instance.new("Frame")
        container.Name = "NotificationContainer_" .. position
        container.Size = UDim2.new(0, 300, 1, 0)
        container.BackgroundTransparency = 1
        container.ZIndex = 10000
        container.Parent = NeonUI.GlobalPopupLayer or CoreGui

        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 8)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
        layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        layout.Parent = container

        local padding = Instance.new("UIPadding")
        padding.PaddingRight = UDim.new(0, 12)
        padding.PaddingBottom = UDim.new(0, 12)
        padding.Parent = container

        if position == "TopLeft" then
            container.Position = UDim2.new(0, 12, 0, 12)
            container.AnchorPoint = Vector2.new(0, 0)
            layout.VerticalAlignment = Enum.VerticalAlignment.Top
            layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            padding.PaddingLeft = UDim.new(0, 12)
            padding.PaddingTop = UDim.new(0, 12)
            padding.PaddingRight = UDim.new(0, 0)
            padding.PaddingBottom = UDim.new(0, 0)
        elseif position == "TopRight" then
            container.Position = UDim2.new(1, -12, 0, 12)
            container.AnchorPoint = Vector2.new(1, 0)
            layout.VerticalAlignment = Enum.VerticalAlignment.Top
            padding.PaddingRight = UDim.new(0, 12)
            padding.PaddingTop = UDim.new(0, 12)
            padding.PaddingLeft = UDim.new(0, 0)
            padding.PaddingBottom = UDim.new(0, 0)
        elseif position == "BottomLeft" then
            container.Position = UDim2.new(0, 12, 1, -12)
            container.AnchorPoint = Vector2.new(0, 1)
            layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
            layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            padding.PaddingLeft = UDim.new(0, 12)
            padding.PaddingBottom = UDim.new(0, 12)
        else -- BottomRight default
            container.Position = UDim2.new(1, -12, 1, -12)
            container.AnchorPoint = Vector2.new(1, 1)
            padding.PaddingRight = UDim.new(0, 12)
            padding.PaddingBottom = UDim.new(0, 12)
        end
        NotificationManager.Containers[position] = container
    end
    return NotificationManager.Containers[position]
end

