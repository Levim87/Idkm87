-- ================== UTILS ==================
local ASSETS = {
    Shadow = "rbxassetid://6014261993",
    Slice = "rbxassetid://3570695787",
    Circle = "rbxassetid://266543268",
}

local function applyShadow(parent, transparency)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.AnchorPoint = Vector2.new(0.5, 0.5)
    shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
    shadow.Size = UDim2.new(1, 20, 1, 20)
    shadow.BackgroundTransparency = 1
    shadow.Image = ASSETS.Shadow
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = transparency or 0.5
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(20, 20, 276, 276)
    shadow.ZIndex = -1
    shadow.Parent = parent
end

local function applyGlow(parent, color, transparency)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.BackgroundTransparency = 1
    glow.Size = UDim2.new(1, 12, 1, 12)
    glow.Position = UDim2.new(0, -6, 0, -6)
    glow.Image = ASSETS.Slice
    glow.ImageColor3 = color
    glow.ImageTransparency = transparency or 0.6
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(10, 10, 246, 246)
    glow.ZIndex = -1
    glow.Parent = parent
end

local function addCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 6)
    corner.Parent = parent
    return corner
end

-- ================== NOTIFICATIONS ==================
NeonUI.Notifications = {}
local notificationCount = 0

function NeonUI:Notify(title, text, duration)
    local theme = self.Themes[self.ActiveTheme]
    if not self.ScreenGui then return end
    duration = duration or 3
    local notify = Instance.new("Frame")
    notify.Size = UDim2.new(0, 260, 0, 60)
    notify.Position = UDim2.new(1, 20, 1, -20)
    notify.AnchorPoint = Vector2.new(1, 1)
    notify.BackgroundColor3 = theme.NotificationBG
    notify.BorderSizePixel = 0
    notify.ClipsDescendants = true
    notify.Parent = self.ScreenGui
    notify.ZIndex = 200

    applyShadow(notify, 0.6)
    addCorner(notify, 6)

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -16, 0, 20)
    titleLabel.Position = UDim2.new(0, 8, 0, 5)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Text = title
    titleLabel.TextColor3 = theme.Accent
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notify

    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, -16, 0, 20)
    textLabel.Position = UDim2.new(0, 8, 0, 28)
    textLabel.Font = Enum.Font.Gotham
    textLabel.Text = text
    textLabel.TextColor3 = theme.NotificationText
    textLabel.TextSize = 12
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Parent = notify

    notificationCount = notificationCount + 1
    local targetPos = UDim2.new(1, -20, 1, -20 - (notificationCount - 1) * 65)
    notify:TweenPosition(targetPos, "Out", "Quad", 0.3)

    delay(duration, function()
        notificationCount = notificationCount - 1
        local fadeOut = TweenService:Create(notify, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 20, notify.Position.Y.Scale, notify.Position.Y.Offset)
        })
        fadeOut:Play()
        fadeOut.Completed:Connect(function()
            notify:Destroy()
        end)
    end)
end

