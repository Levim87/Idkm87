                        satValCanvas.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                        hexBox.Text = string.format("#%02x%02x%02x", currentColor.R*255, currentColor.G*255, currentColor.B*255)
                        callback(currentColor)
                    end

                    local function updateFromSatVal(pos)
                        local absPos = satValCanvas.AbsolutePosition
                        local absSize = satValCanvas.AbsoluteSize
                        local relX = math.clamp((pos.X - absPos.X) / absSize.X, 0, 1)
                        local relY = math.clamp((pos.Y - absPos.Y) / absSize.Y, 0, 1)
                        s = relX
                        v = 1 - relY
                        updateColorFromHSV()
                    end

                    local function updateFromHue(pos)
                        local absPos = hueSlider.AbsolutePosition
                        local absSize = hueSlider.AbsoluteSize
                        local relX = math.clamp((pos.X - absPos.X) / absSize.X, 0, 1)
                        h = relX
                        updateColorFromHSV()
                    end

                    satValCanvas.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            satValDragging = true
                            updateFromSatVal(UserInputService:GetMouseLocation())
                        end
                    end)

                    hueSlider.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            hueDragging = true
                            updateFromHue(UserInputService:GetMouseLocation())
                        end
                    end)

                    UserInputService.InputChanged:Connect(function(input)
                        if satValDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                            updateFromSatVal(UserInputService:GetMouseLocation())
                        elseif hueDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                            updateFromHue(UserInputService:GetMouseLocation())
                        end
                    end)

                    UserInputService.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            satValDragging = false
                            hueDragging = false
                        end
                    end)

                    hexBox.FocusLost:Connect(function()
                        local hex = hexBox.Text:gsub("#", "")
                        local r = tonumber(hex:sub(1,2), 16) or 0
                        local g = tonumber(hex:sub(3,4), 16) or 0
                        local b = tonumber(hex:sub(5,6), 16) or 0
                        currentColor = Color3.fromRGB(r, g, b)
                        h, s, v = Color3.toHSV(currentColor)
                        updateColorFromHSV()
                    end)

                    applyBtn.MouseButton1Click:Connect(function()
                        callback(currentColor)
                        if pickerFrame and pickerFrame.Parent then pickerFrame:Destroy() end
                        colorPickerOpen = false
                    end)

                    return popupFrame
                end

                local function openColorPicker()
                    if colorPickerOpen then return end
                    colorPickerOpen = true
                    local popup = createColorPickerPopup()
                    local _, _ = NeonUI:CreatePopup(function(parent)
                        popup.Parent = parent
                        return popup
                    end, preview, 0, 2, function()
                        colorPickerOpen = false
                        pickerFrame = nil
                    end)
                    pickerFrame = popup
                end

                preview.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        openColorPicker()
                    end
                end)

                return {
                    SetColor = function(col)
                        currentColor = col
                        h, s, v = Color3.toHSV(col)
                        preview.BackgroundColor3 = col
                        callback(col)
                    end,
                    GetColor = function() return currentColor end
                }
