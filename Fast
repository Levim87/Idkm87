    function Window:SelectTab(tab)
        for _, t in ipairs(Window.Tabs) do
            t.Content.Visible = false
            t.Button.BackgroundColor3 = theme.Tab
            t.Button.TextColor3 = theme.Text
        end
        tab.Content.Visible = true
        tab.Button.BackgroundColor3 = theme.Accent
        tab.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Window.SelectedTab = tab
    end

    function Window:Destroy()
        ScreenGui:Destroy()
        for i, w in ipairs(WindowManager.Windows) do
            if w == Window then table.remove(WindowManager.Windows, i) break end
        end
    end

    function Window:Minimize()
        minimize()
    end

    function Window:Restore()
        if Window.Minimized then minimize() end
    end

    function Window:Focus()
