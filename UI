        })
        
        local listening = false
        Kb.MouseEnter:Connect(function() Utility:Tween(KbStroke, {Color = Nova.Theme.Accent}, 0.15) end)
        Kb.MouseLeave:Connect(function() Utility:Tween(KbStroke, {Color = Nova.Theme.Outline}, 0.15) end)
        
        Kb.MouseButton1Click:Connect(function()
            listening = true
            Val.Text = "[...]"
        end)
        
        local function UpdateState(keyCode)
            Nova.Flags[flag] = keyCode
            Val.Text = "["..keyCode.Name.."]"
        end
        
        local inputConn = UserInputService.InputBegan:Connect(function(input, gpe)
            if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                UpdateState(input.KeyCode)
            elseif not gpe and input.KeyCode == Nova.Flags[flag] then
                cb()
            end
        end)
        table_insert(Nova.Connections, inputConn)
        Nova.Registry[flag] = UpdateState
    end

