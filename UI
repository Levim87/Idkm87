    local layout = {
        Width = isMobile and 460 or 620,
        Height = isMobile and 300 or 420,
        SidebarWidth = isMobile and 120 or 160,
        TitleSize = isMobile and 13 or 16,
        ElementSize = isMobile and 11 or 13,
        ElementHeight = isMobile and 32 or 38
