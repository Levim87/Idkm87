        function tab:MultiSelect(
            text: string,
            flag: string,
            opts: {string},
            default: {string}?,
            cb: ({string}) -> ()
        )
            lib.Flags[flag] = default or {} :: FlagValue
            local baseH = scale.RowHeight
            local expanded = false

            local container: Frame = make("Frame", {
                Size = new(0.93, 0, 0, baseH),
                BackgroundColor3 = theme.Raised,
                ClipsDescendants = true,
            }, page)
            corner(theme.Radius, container)
            local s = stroke(theme.Border, 1, container)

            local trigger: TextButton = make("TextButton", {
                Size = new(1, 0, 0, baseH),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
            }, container)

            local lbl = createLabel(trigger, text, 30)
            cacheLabel(container, lbl)

            local valueTag: TextLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = new(1, -28, 0.5, 0),
                Size = new(0, 80, 0, 14),
                Text = "None",
                Font = Enum.Font.GothamMedium,
                TextSize = scale.TagSize,
                TextColor3 = theme.Accent,
                BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Right,
            }, trigger)

            local arrow: TextLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = new(1, -10, 0.5, 0),
                Size = new(0, 14, 0, 14),
                Text = "▾",
                Font = Enum.Font.GothamBold,
                TextSize = 11,
                TextColor3 = theme.Muted,
                BackgroundTransparency = 1,
            }, trigger)

            local list: Frame = make("Frame", {
                Position = new(0, 0, 0, baseH),
                Size = new(1, 0, 0, 0),
                BackgroundTransparency = 1,
            }, container)
            local itemLayout = listLayout(list, 2)
            itemLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
            make("UIPadding", {PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4)}, list)

            local function refreshTitle()
                local sel = lib.Flags[flag] :: {string}
                if #sel == 0 then
                    valueTag.Text = "None"
                elseif #sel > 2 then
                    valueTag.Text = tostring(#sel) .. " selected"
                else
                    valueTag.Text = table.concat(sel, ", ")
                end
            end

            local itemBtns: {TextButton} = {}

            local function buildItems()
                for _, ch in list:GetChildren() do
                    if ch:IsA("TextButton") then ch:Destroy() end
                end
                table.clear(itemBtns)

                local sel = lib.Flags[flag] :: {string}
                for _, opt in opts do
                    local active = tblHas(sel, opt)
                    local item: TextButton = make("TextButton", {
                        Size = new(0.94, 0, 0, scale.RowHeight - 12),
                        BackgroundColor3 = active and theme.Accent or theme.Surface,
                        Text = "",
                        AutoButtonColor = false,
                    }, list)
                    corner(UDim.new(0, 4), item)
                    table.insert(itemBtns, item)

                    make("TextLabel", {
                        Position = new(0, 10, 0, 0),
                        Size = new(1, -20, 1, 0),
                        Text = opt,
                        Font = Enum.Font.GothamMedium,
                        TextSize = scale.BodySize,
                        TextColor3 = theme.Text,
                        BackgroundTransparency = 1,
                        TextXAlignment = Enum.TextXAlignment.Left,
                    }, item)

                    track(item.MouseEnter:Connect(function()
                        if not tblHas(lib.Flags[flag] :: {string}, opt) then
                            tween(item, {BackgroundColor3 = theme.Hover}, 0.1)
                        end
                    end))
                    track(item.MouseLeave:Connect(function()
                        if not tblHas(lib.Flags[flag] :: {string}, opt) then
                            tween(item, {BackgroundColor3 = theme.Surface}, 0.1)
                        end
                    end))
                    track(item.MouseButton1Click:Connect(function()
                        local current = lib.Flags[flag] :: {string}
                        if tblHas(current, opt) then
                            tblRemove(current, opt)
                        else
                            table.insert(current, opt)
                        end
                        refreshTitle()
                        cb(current)
                        buildItems()
                    end))
                end
            end

            track(trigger.MouseButton1Click:Connect(function()
                expanded = not expanded
                local listH = itemLayout.AbsoluteContentSize.Y + 10
                local targetH = expanded and (baseH + listH) or baseH
                tween(container, {Size = new(0.93, 0, 0, targetH)}, 0.18)
                arrow.Text = expanded and "▴" or "▾"
                tween(s, {Color = expanded and theme.Accent or theme.Border}, 0.12)
            end))

            local function setState(v: {string})
                lib.Flags[flag] = v
                refreshTitle()
                buildItems()
                cb(v)
            end
            lib.Registry[flag] = function(v) setState(v :: {string}) end

            buildItems()
            refreshTitle()
            if default and #default > 0 then task.spawn(cb, default) end
        end

        function tab:Textbox(
            text: string,
            flag: string,
            default: string?,
            placeholder: string?,
            cb: (string, boolean) -> ()
        )
            lib.Flags[flag] = default or ""

            local h = scale.RowHeight
            local boxW = isMobile and 100 or 130

            local frame = rowFrame(h)
            local lbl = createLabel(frame, text, boxW + 20)
            cacheLabel(frame, lbl)

            local boxHolder: Frame = make("Frame", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = new(1, -12, 0.5, 0),
                Size = new(0, boxW, 0, 26),
                BackgroundColor3 = theme.Surface,
            }, frame)
            corner(UDim.new(0, 5), boxHolder)
            local boxS = stroke(theme.Border, 1, boxHolder)

            local input: TextBox = make("TextBox", {
                Position = new(0, 8, 0, 0),
                Size = new(1, -16, 1, 0),
                BackgroundTransparency = 1,
                Text = default or "",
                PlaceholderText = placeholder or "Enter value…",
                PlaceholderColor3 = theme.Muted,
                TextColor3 = theme.Text,
                Font = Enum.Font.GothamMedium,
                TextSize = scale.BodySize,
                TextXAlignment = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
            }, boxHolder)

            track(input.Focused:Connect(function()
                tween(boxS, {Color = theme.Accent}, 0.12)
                tween(boxHolder, {BackgroundColor3 = fromRGB(15, 15, 20)}, 0.12)
            end))
            track(input.FocusLost:Connect(function(enter)
                tween(boxS, {Color = theme.Border}, 0.12)
                tween(boxHolder, {BackgroundColor3 = theme.Surface}, 0.12)
                lib.Flags[flag] = input.Text
                cb(input.Text, enter)
            end))

            local function setState(v: string)
                lib.Flags[flag] = v
                input.Text = v
                cb(v, false)
            end
            lib.Registry[flag] = function(v) setState(v :: string) end
            task.spawn(cb, default or "", false)
        end

        function tab:Keybind(text: string, flag: string, default: Enum.KeyCode, cb: () -> ())
            lib.Flags[flag] = default

            local frame = rowFrame(scale.RowHeight)
            local lbl = createLabel(frame, text, 80)
            cacheLabel(frame, lbl)

            local keyTag: TextLabel = make("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = new(1, -12, 0.5, 0),
                Size = new(0, 70, 0, 22),
                Text = "[" .. (default :: Enum.KeyCode).Name .. "]",
                Font = Enum.Font.GothamBold,
                TextSize = scale.TagSize,
                TextColor3 = theme.Accent,
                BackgroundColor3 = theme.Surface,
                TextXAlignment = Enum.TextXAlignment.Center,
            }, frame)
            corner(UDim.new(0, 4), keyTag)
            stroke(theme.Border, 1, keyTag)

            local listening = false

            local clickBtn: TextButton = make("TextButton", {
                Size = new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
            }, keyTag)
            track(clickBtn.MouseButton1Click:Connect(function()
                listening = true
                keyTag.Text = "[…]"
                tween(keyTag, {TextColor3 = theme.Muted}, 0.1)
            end))

            track(UserInputService.InputBegan:Connect(function(i, gp)
                if listening and i.UserInputType == Enum.UserInputType.Keyboard then
                    listening = false
                    lib.Flags[flag] = i.KeyCode
                    keyTag.Text = "[" .. i.KeyCode.Name .. "]"
                    tween(keyTag, {TextColor3 = theme.Accent}, 0.1)
                elseif not gp and i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == lib.Flags[flag] then
                    task.spawn(cb)
                end
            end))

            local function setState(v: Enum.KeyCode)
                lib.Flags[flag] = v
                keyTag.Text = "[" .. v.Name .. "]"
            end
            lib.Registry[flag] = function(v) setState(v :: Enum.KeyCode) end
        end

        function tab:ColorPicker(text: string, flag: string, default: Color3, cb: (Color3) -> ())
            lib.Flags[flag] = default

            local baseH = scale.RowHeight
            local expanded = false
            local PICKER_H = 110

            local container: Frame = make("Frame", {
                Size = new(0.93, 0, 0, baseH),
                BackgroundColor3 = theme.Raised,
                ClipsDescendants = true,
            }, page)
            corner(theme.Radius, container)
            local s = stroke(theme.Border, 1, container)

            local trigger: TextButton = make("TextButton", {
                Size = new(1, 0, 0, baseH),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
            }, container)
            local lbl = createLabel(trigger, text, 46)
            cacheLabel(container, lbl)

            local swatch: Frame = make("Frame", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = new(1, -12, 0.5, 0),
                Size = new(0, 30, 0, 18),
                BackgroundColor3 = default,
            }, trigger)
            corner(UDim.new(0, 4), swatch)
            stroke(theme.Border, 1, swatch)

            local panel: Frame = make("Frame", {
                Position = new(0, 8, 0, baseH + 6),
                Size = new(1, -16, 0, PICKER_H),
                BackgroundTransparency = 1,
            }, container)

            local svBox: Frame = make("Frame", {
                Size = new(0, PICKER_H - 20, 0, PICKER_H - 20),
                BackgroundColor3 = fromRGB(255, 0, 0),
            }, panel)
            corner(UDim.new(0, 4), svBox)

            local whiteGrad: Frame = make("Frame", {Size = new(1,0,1,0), BackgroundColor3 = fromRGB(255,255,255)}, svBox)
            make("UIGradient", {Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0),
                NumberSequenceKeypoint.new(1, 1),
            }), Rotation = 0}, whiteGrad)

            local blackGrad: Frame = make("Frame", {Size = new(1,0,1,0), BackgroundColor3 = fromRGB(0,0,0)}, svBox)
            make("UIGradient", {Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0),
            }), Rotation = 90}, blackGrad)

            local svCursor: Frame = make("Frame", {
                Size = new(0, 8, 0, 8),
                BackgroundColor3 = fromRGB(255,255,255),
                ZIndex = 10,
            }, svBox)
            corner(UDim.new(1, 0), svCursor)
            stroke(fromRGB(0,0,0), 1, svCursor)

            local hueStrip: Frame = make("Frame", {
                Position = new(0, PICKER_H - 10, 0, 0),
                Size = new(1, -(PICKER_H - 6), 0, PICKER_H - 20),
            }, panel)
            corner(UDim.new(0, 3), hueStrip)

            local hueKps: {ColorSequenceKeypoint} = {}
            for i = 0, 6 do
                local h = i / 6
                table.insert(hueKps, ColorSequenceKeypoint.new(h, Color3.fromHSV(h, 1, 1)))
            end
            make("UIGradient", {Color = ColorSequence.new(hueKps), Rotation = 90}, hueStrip)

            local hueCursor: Frame = make("Frame", {
                Size = new(1, 0, 0, 4),
                BackgroundColor3 = fromRGB(255,255,255),
                ZIndex = 10,
            }, hueStrip)
            stroke(fromRGB(0,0,0), 1, hueCursor)

            local h_, s_, v_ = Color3.toHSV(default)

            local function updateColor()
                local c = Color3.fromHSV(h_, s_, v_)
                lib.Flags[flag] = c
                swatch.BackgroundColor3 = c
                svBox.BackgroundColor3 = Color3.fromHSV(h_, 1, 1)
                cb(c)
            end

            svCursor.Position = new(s_, -4, 1 - v_, -4)
            hueCursor.Position = new(0, 0, h_, -2)

            local svDrag = false
            track(svBox.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDrag = true
                end
            end))
            track(UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDrag = false
                end
            end))
            track(UserInputService.InputChanged:Connect(function(i)
                if not svDrag then return end
                if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                s_ = math.clamp((i.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                v_ = 1 - math.clamp((i.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                svCursor.Position = new(s_, -4, 1 - v_, -4)
                updateColor()
            end))

            local hueDrag = false
            track(hueStrip.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    hueDrag = true
                end
            end))
            track(UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    hueDrag = false
                end
            end))
            track(UserInputService.InputChanged:Connect(function(i)
                if not hueDrag then return end
                if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                h_ = math.clamp((i.Position.Y - hueStrip.AbsolutePosition.Y) / hueStrip.AbsoluteSize.Y, 0, 1)
                hueCursor.Position = new(0, 0, h_, -2)
                svBox.BackgroundColor3 = Color3.fromHSV(h_, 1, 1)
                updateColor()
            end))

            track(trigger.MouseButton1Click:Connect(function()
                expanded = not expanded
                local targetH = expanded and (baseH + PICKER_H + 12) or baseH
                tween(container, {Size = new(0.93, 0, 0, targetH)}, 0.18)
                tween(s, {Color = expanded and theme.Accent or theme.Border}, 0.12)
            end))

            local function setState(v: Color3)
                lib.Flags[flag] = v
                swatch.BackgroundColor3 = v
                h_, s_, v_ = Color3.toHSV(v)
                svBox.BackgroundColor3 = Color3.fromHSV(h_, 1, 1)
                svCursor.Position = new(s_, -4, 1 - v_, -4)
                hueCursor.Position = new(0, 0, h_, -2)
                cb(v)
            end
            lib.Registry[flag] = function(v) setState(v :: Color3) end
            task.spawn(cb, default)
        end

        return tab
    end

    function lib:Destroy()
        for _, c in lib.Connections do
            pcall(function() c:Disconnect() end)
        end
        table.clear(lib.Connections)
        gui:Destroy()
    end

    lib:Notify("Levi", "UI ready.", 3)
    return lib
end

return Levi
