        Name = "LeviUI",
        Parent = parentContainer,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Global
    })

    local mainFrame = util.create("Frame", {
        Parent = screenGui,
        Position = UDim2.new(0.5, -layout.Width / 2, 0.5, -layout.Height / 2),
        Size = UDim2.new(0, layout.Width, 0, layout.Height),
        BackgroundColor3 = self.Theme.Background,
        ClipsDescendants = true
    })
    util.create("UICorner", {CornerRadius = self.Theme.Corner, Parent = mainFrame})
    util.create("UIStroke", {Color = self.Theme.Outline, Thickness = 1, Parent = mainFrame})

    if useParticles then
        local particleContainer = util.create("Frame", {
            Parent = mainFrame,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = 0
        })
        
        task.spawn(function()
            local particles = {}
            for _ = 1, 15 do
                local p = util.create("Frame", {
                    Parent = particleContainer,
                    Size = UDim2.new(0, 3, 0, 3),
                    BackgroundColor3 = self.Theme.Accent,
                    Position = UDim2.new(math.random(), 0, math.random(), 0),
                    BackgroundTransparency = 0.8
                })
                util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = p})
                table.insert(particles, {
                    inst = p,
                    speedX = (math.random() - 0.5) * 0.0008,
                    speedY = (math.random() - 0.5) * 0.0008
                })
            end
            
            local conn = RunService.RenderStepped:Connect(function()
                for _, p in ipairs(particles) do
                    local newX = p.inst.Position.X.Scale + p.speedX
                    local newY = p.inst.Position.Y.Scale + p.speedY
                    if newX <= 0 or newX >= 1 then p.speedX = -p.speedX end
                    if newY <= 0 or newY >= 1 then p.speedY = -p.speedY end
                    p.inst.Position = UDim2.new(newX, 0, newY, 0)
                end
            end)
            table.insert(self.Connections, conn)
        end)
    end

