        BorderSizePixel = 0, 
        BackgroundTransparency = 1
    })
    local tLabel = Utility:Create("TextLabel", {
        Parent = notif, 
        Position = UDim2_new(0, 14, 0, 6), 
        Size = UDim2_new(1, -20, 0, 18), 
        Text = title, 
        Font = Enum.Font.GothamBold, 
        TextSize = LayoutScale.TextSize_Element, 
        TextColor3 = Nova.Theme.Text, 
        BackgroundTransparency = 1, 
        TextXAlignment = Enum.TextXAlignment.Left, 
        TextTransparency = 1
    })
    local bLabel = Utility:Create("TextLabel", {
        Parent = notif, 
        Position = UDim2_new(0, 14, 0, 24), 
        Size = UDim2_new(1, -20, 0, 24), 
        Text = text, 
        Font = Enum.Font.Gotham, 
        TextSize = LayoutScale.TextSize_Element - 2, 
        TextColor3 = Nova.Theme.Muted, 
        BackgroundTransparency = 1, 
        TextXAlignment = Enum.TextXAlignment.Left, 
        TextWrapped = true, 
        TextTransparency = 1
    })
    
    Utility:Tween(notif, {BackgroundTransparency = 0}, 0.25)
    Utility:Tween(stroke, {Transparency = 0}, 0.25)
    Utility:Tween(accentBar, {BackgroundTransparency = 0}, 0.25)
    Utility:Tween(tLabel, {TextTransparency = 0}, 0.25)
    Utility:Tween(bLabel, {TextTransparency = 0}, 0.25)
    
    task_delay(time or 3.5, function()
        Utility:Tween(notif, {BackgroundTransparency = 1}, 0.25)
        Utility:Tween(stroke, {Transparency = 1}, 0.25)
        Utility:Tween(accentBar, {BackgroundTransparency = 1}, 0.25)
        Utility:Tween(tLabel, {TextTransparency = 1}, 0.25)
        Utility:Tween(bLabel, {TextTransparency = 1}, 0.25)
        task_wait(0.25)
        notif:Destroy()
    end)
end

-- // Search Filter Logic
SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local query = string_lower(SearchBox.Text)
    local activePage = nil
    for _, p in ipairs(PagesContainer:GetChildren()) do
        if p:IsA("ScrollingFrame") and p.Visible then
            activePage = p
            break
        end
    end
    if activePage then
        for _, elem in ipairs(activePage:GetChildren()) do
            if elem:IsA("Frame") or elem:IsA("TextButton") then
                local label = FindTextLabel(elem)
                if label then
                    local text = string_lower(label.Text)
                    local cleanText = string_gsub(text, "<[^>]+>", "")
                    if string_find(cleanText, query) or query == "" then
                        elem.Visible = true
                    else
                        elem.Visible = false
                    end
                end
            end
        end
    end
end)

