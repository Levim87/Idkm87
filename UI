-- // Utility Helper Functions
local Utility = {}

function Utility:Create(class, props)
    local inst = Instance.new(class)
    for i, v in pairs(props) do 
        inst[i] = v 
    end
    return inst
end

function Utility:Tween(obj, props, duration, style, direction)
    local info = TweenInfo.new(
        duration or 0.18, 
        style or Enum.EasingStyle.Quad, 
        direction or Enum.EasingDirection.Out
    )
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

function Utility:Draggable(topbar, frame)
    local dragging, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2_new(
                startPos.X.Scale, startPos.X.Offset + delta.X, 
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false 
        end
    end)
end

-- Safe Multi-Select Table Helpers
local function table_has(tbl, val)
    return table_find(tbl, val) ~= nil
end

local function table_remove_value(tbl, val)
    local index = table_find(tbl, val)
    if index then
        table_remove(tbl, index)
    end
end

-- Helper to recursively identify readable labels inside elements for searching
local function FindTextLabel(parent)
    for _, child in ipairs(parent:GetDescendants()) do
        if child:IsA("TextLabel") and child.Text ~= "" and child.Text ~= "▼" and child.Text ~= "▲" and child.Text ~= "—" then
            return child
        end
    end
    return nil
end

-- // Configuration Storage API
function Nova:SaveConfig(fileName)
    fileName = fileName or "NovaConfig.json"
    local success, err = pcall(function()
        if writefile then
            local serialized = HttpService:JSONEncode(Nova.Flags)
            writefile(fileName, serialized)
            Nova:Notify("Configuration Saved", "Options written to " .. fileName, 3)
        else
            Nova:Notify("Config Failure", "Current execution host lacks writefile permission.", 3)
        end
    end)
    if not success then warn("[Nova UI Engine] Save error: " .. tostring(err)) end
end

function Nova:LoadConfig(fileName)
    fileName = fileName or "NovaConfig.json"
    local success, err = pcall(function()
        if readfile and isfile and isfile(fileName) then
            local data = HttpService:JSONDecode(readfile(fileName))
            if data then
                for k, v in pairs(data) do
                    Nova.Flags[k] = v
                    -- Dynamically update visual elements to correspond with loaded settings
                    local callback = Nova.Registry[k]
                    if callback then
                        pcall(callback, v)
                    end
                end
                Nova:Notify("Configuration Loaded", "Applied options from " .. fileName, 3)
            end
        else
            Nova:Notify("Config Missing", "No configuration file found at destination.", 3)
        end
    end)
    if not success then warn("[Nova UI Engine] Load error: " .. tostring(err)) end
end

