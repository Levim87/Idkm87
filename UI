            Text = "",
            AutoButtonColor = false
        })
        util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = tabBtn})
        local tabStroke = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = tabBtn, Transparency = 1})
        
        local tabText = util.create("TextLabel", {
            Parent = tabBtn,
            Size = UDim2.new(1, 0, 1, 0),
            Text = name,
            Font = Enum.Font.GothamMedium,
            TextSize = layout.ElementSize,
            TextColor3 = Levi.Theme.Muted,
            BackgroundTransparency = 1
        })
        
        table.insert(self.Pages, page)
        table.insert(self.TabBtns, {btn = tabBtn, txt = tabText, strk = tabStroke})
        
        if self.Tabs == 1 then 
            page.Visible = true 
            tabBtn.BackgroundColor3 = Levi.Theme.Element 
            tabText.TextColor3 = Levi.Theme.Text
            tabStroke.Transparency = 0
        end
        
        tabBtn.MouseEnter:Connect(function()
            if not page.Visible then util.tween(tabText, {TextColor3 = Levi.Theme.Text}) end
        end)
        
        tabBtn.MouseLeave:Connect(function()
            if not page.Visible then util.tween(tabText, {TextColor3 = Levi.Theme.Muted}) end
        end)
        
        tabBtn.MouseButton1Click:Connect(function()
            searchBox.Text = "" 
            for _, p in ipairs(self.Pages) do p.Visible = false end 
            for _, b in ipairs(self.TabBtns) do 
                util.tween(b.btn, {BackgroundColor3 = Levi.Theme.Sidebar})
                util.tween(b.txt, {TextColor3 = Levi.Theme.Muted})
                util.tween(b.strk, {Transparency = 1})
            end 
            page.Visible = true
            util.tween(tabBtn, {BackgroundColor3 = Levi.Theme.Element})
            util.tween(tabText, {TextColor3 = Levi.Theme.Text})
            util.tween(tabStroke, {Transparency = 0})
        end)

        local TabElements = {}

