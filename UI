SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local query = string_lower(SearchBox.Text)
    local activePage = nil
    for _, p in ipairs(PagesContainer:GetChildren()) do
        if p:IsA("ScrollingFrame") and p.Visible then
            activePage = p
            break
        end
    end
    if activePage then
        for _, elem in ipairs(activePage:GetChildren()) do
            if elem:IsA("Frame") or elem:IsA("TextButton") then
                local label = FindTextLabel(elem)
                if label then
                    local text = string_lower(label.Text)
                    local cleanText = string_gsub(text, "<[^>]+>", "")
                    if string_find(cleanText, query) or query == "" then
                        elem.Visible = true
                    else
                        elem.Visible = false
                    end
                end
            end
        end
    end
end)

