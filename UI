            AnchorPoint = Vector2_new(0.5, 0.5), 
            Position = UDim2_new((default - min)/(max - min), 0, 0.5, 0), 
            Size = UDim2_new(0, 10, 0, 10), -- Compact 10x10 knob
            BackgroundColor3 = Nova.Theme.Text
        })
        Utility:Create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = SliderBtn})
        
        local Dragging = false
        local function UpdateState(inputOrVal)
            local value
            if typeof(inputOrVal) == "number" then
                value = math_clamp(inputOrVal, min, max)
            else
                local pct = math_clamp((inputOrVal.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                value = math_floor(min + ((max - min) * pct))
            end
            
            local pct = (value - min) / (max - min)
            Nova.Flags[flag] = value
            Val.Text = tostring(value)
            
            Utility:Tween(Fill, {Size = UDim2_new(pct, 0, 1, 0)}, 0.05)
            Utility:Tween(SliderBtn, {Position = UDim2_new(pct, 0, 0.5, 0)}, 0.05)
            cb(value)
        end
        
        Sldr.InputBegan:Connect(function(inp) 
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then 
                Dragging = true 
                UpdateState(inp) 
            end 
        end)
        UserInputService.InputEnded:Connect(function(inp) 
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then 
                Dragging = false 
            end 
        end)
        UserInputService.InputChanged:Connect(function(inp) 
            if Dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then 
                UpdateState(inp) 
            end 
        end)
        
        Nova.Registry[flag] = UpdateState
        cb(default)
    end

