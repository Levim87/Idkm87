    })
    util.create("UIListLayout", {
        Parent = notifContainer,
        Padding = UDim.new(0, 8),
        VerticalAlignment = Enum.VerticalAlignment.Bottom
    })

    -- Search Logic
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = string.lower(searchBox.Text)
        for _, page in ipairs(pagesContainer:GetChildren()) do
            if page:IsA("ScrollingFrame") and page.Visible then
                for _, elem in ipairs(page:GetChildren()) do
                    if elem:IsA("Frame") or elem:IsA("TextButton") then
                        local label = nil
                        for _, child in ipairs(elem:GetDescendants()) do
                            if child:IsA("TextLabel") and child.Text ~= "" and child.Text ~= "▼" and child.Text ~= "▲" then
                                label = child
                                break
                            end
                        end
                        if label then
                            local text = string.lower(label.Text:gsub("<[^>]+>", ""))
                            elem.Visible = string.find(text, query) ~= nil or query == ""
                        end
                    end
                end
            end
        end
    end)

    local Window = {
        Tabs = 0,
        Pages = {},
        TabBtns = {}
    }

    function Window:Notify(title, text, time)
        local notif = util.create("Frame", {
            Parent = notifContainer,
            Size = UDim2.new(1, 0, 0, 56),
            BackgroundColor3 = Levi.Theme.Sidebar,
            BackgroundTransparency = 1
        })
        util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = notif})
        local stroke = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = notif, Transparency = 1})
        
        local accentBar = util.create("Frame", {
            Parent = notif,
            Size = UDim2.new(0, 4, 1, 0),
            BackgroundColor3 = Levi.Theme.Accent,
            BorderSizePixel = 0,
            BackgroundTransparency = 1
        })
        local tLabel = util.create("TextLabel", {
            Parent = notif,
            Position = UDim2.new(0, 14, 0, 6),
            Size = UDim2.new(1, -20, 0, 18),
            Text = title,
            Font = Enum.Font.GothamBold,
            TextSize = layout.ElementSize,
            TextColor3 = Levi.Theme.Text,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTransparency = 1
        })
        local bLabel = util.create("TextLabel", {
            Parent = notif,
            Position = UDim2.new(0, 14, 0, 24),
            Size = UDim2.new(1, -20, 0, 24),
            Text = text,
            Font = Enum.Font.Gotham,
            TextSize = layout.ElementSize - 2,
            TextColor3 = Levi.Theme.Muted,
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            TextTransparency = 1
        })
        
        util.tween(notif, {BackgroundTransparency = 0})
        util.tween(stroke, {Transparency = 0})
        util.tween(accentBar, {BackgroundTransparency = 0})
        util.tween(tLabel, {TextTransparency = 0})
        util.tween(bLabel, {TextTransparency = 0})
        
        task.delay(time or 3, function()
            util.tween(notif, {BackgroundTransparency = 1})
            util.tween(stroke, {Transparency = 1})
            util.tween(accentBar, {BackgroundTransparency = 1})
            util.tween(tLabel, {TextTransparency = 1})
            util.tween(bLabel, {TextTransparency = 1})
            task.wait(0.25)
            notif:Destroy()
        end)
    end

    function Window:SaveConfig(filename)
        filename = filename or "LeviConfig.json"
        pcall(function()
            if writefile then
                writefile(filename, HttpService:JSONEncode(Levi.Flags))
                self:Notify("Config Saved", "Saved to " .. filename, 3)
            end
        end)
    end

    function Window:LoadConfig(filename)
        filename = filename or "LeviConfig.json"
        pcall(function()
            if readfile and isfile and isfile(filename) then
                local data = HttpService:JSONDecode(readfile(filename))
                for k, v in pairs(data) do
                    Levi.Flags[k] = v
                    if Levi.Registry[k] then Levi.Registry[k](v) end
                end
                self:Notify("Config Loaded", "Loaded from " .. filename, 3)
            end
        end)
    end

