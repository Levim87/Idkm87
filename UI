            btn.MouseButton1Up:Connect(function() util.tween(btn, {Size = UDim2.new(0.92, 0, 0, h)}, 0.08); cb() end)
        end

        function TabElements:CreateToggle(options)
            local title = options.Title or "Toggle"
            local flag = options.Flag or title
            local desc = options.Description
            local default = options.Default or false
            local cb = options.Callback or function() end
            local h = desc and (layout.ElementHeight + 12) or layout.ElementHeight
            
            Levi.Flags[flag] = default
            
            local tgl = util.create("TextButton", {
                Parent = page,
                Size = UDim2.new(0.92, 0, 0, h),
                BackgroundColor3 = Levi.Theme.Element,
                Text = "",
                AutoButtonColor = false
            })
            util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = tgl})
            local strk = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = tgl})
            
            local textFrame = util.create("Frame", {
                Parent = tgl, Position = UDim2.new(0, 16, 0, 0),
                Size = UDim2.new(1, -70, 1, 0), BackgroundTransparency = 1
            })
            util.create("UIListLayout", {
                Parent = textFrame, SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 1)
            })
            
            util.create("TextLabel", {
                Parent = textFrame, Size = UDim2.new(1, 0, 0, 16),
                Text = title, Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize,
                TextColor3 = Levi.Theme.Text, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            if desc then
                util.create("TextLabel", {
                    Parent = textFrame, Size = UDim2.new(1, 0, 0, 14),
                    Text = desc, Font = Enum.Font.Gotham, TextSize = layout.ElementSize - 2,
                    TextColor3 = Levi.Theme.Muted, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
                })
            end
            
            local ind = util.create("Frame", {
                Parent = tgl, AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -16, 0.5, 0), Size = UDim2.new(0, 32, 0, 16),
                BackgroundColor3 = Levi.Flags[flag] and Levi.Theme.Accent or Color3.fromRGB(45, 45, 55)
            })
            util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = ind})
            
            local dot = util.create("Frame", {
                Parent = ind, AnchorPoint = Vector2.new(0, 0.5),
                Position = Levi.Flags[flag] and UDim2.new(1, -14, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                Size = UDim2.new(0, 12, 0, 12), BackgroundColor3 = Levi.Theme.Text
            })
            util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = dot})
            
            tgl.MouseEnter:Connect(function() util.tween(strk, {Color = Levi.Theme.Accent}) end)
            tgl.MouseLeave:Connect(function() util.tween(strk, {Color = Levi.Theme.Outline}) end)
            
            local function update(state)
                Levi.Flags[flag] = state
                util.tween(ind, {BackgroundColor3 = state and Levi.Theme.Accent or Color3.fromRGB(45, 45, 55)})
                util.tween(dot, {Position = state and UDim2.new(1, -14, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)})
                cb(state)
            end
            
            tgl.MouseButton1Click:Connect(function() update(not Levi.Flags[flag]) end)
            Levi.Registry[flag] = update
            if default then cb(default) end
        end

        function TabElements:CreateSlider(options)
            local title = options.Title or "Slider"
            local flag = options.Flag or title
            local desc = options.Description
            local min = options.Min or 0
            local max = options.Max or 100
            local default = options.Default or min
            local cb = options.Callback or function() end
            
            local h = desc and 54 or 42
            local barY = desc and 38 or 26
            Levi.Flags[flag] = default
            
            local sldr = util.create("Frame", {
                Parent = page, Size = UDim2.new(0.92, 0, 0, h),
                BackgroundColor3 = Levi.Theme.Element
            })
            util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = sldr})
            local strk = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = sldr})
            
            util.create("TextLabel", {
                Parent = sldr, Position = UDim2.new(0, 16, 0, 6),
                Size = UDim2.new(0.7, 0, 0, 16), Text = title,
                Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize,
                TextColor3 = Levi.Theme.Text, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            if desc then
                util.create("TextLabel", {
                    Parent = sldr, Position = UDim2.new(0, 16, 0, 20),
                    Size = UDim2.new(1, -32, 0, 14), Text = desc,
                    Font = Enum.Font.Gotham, TextSize = layout.ElementSize - 2,
                    TextColor3 = Levi.Theme.Muted, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
                })
            end
            
            local valLbl = util.create("TextLabel", {
                Parent = sldr, Position = UDim2.new(0.7, -16, 0, 6),
                Size = UDim2.new(0.3, 0, 0, 16), Text = tostring(default),
                Font = Enum.Font.GothamBold, TextSize = layout.ElementSize - 1,
                TextColor3 = Levi.Theme.Accent, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local bar = util.create("Frame", {
                Parent = sldr, Position = UDim2.new(0, 16, 0, barY),
                Size = UDim2.new(1, -32, 0, 4), BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            })
            util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = bar})
            
            local fill = util.create("Frame", {
                Parent = bar, Size = UDim2.new((default - min)/(max - min), 0, 1, 0),
                BackgroundColor3 = Levi.Theme.Accent
            })
            util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})
            
            local knob = util.create("Frame", {
                Parent = bar, AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((default - min)/(max - min), 0, 0.5, 0),
                Size = UDim2.new(0, 10, 0, 10), BackgroundColor3 = Levi.Theme.Text
            })
            util.create("UICorner", {CornerRadius = UDim.new(1, 0), Parent = knob})
            
            local dragging = false
            local function update(input)
                local value
                if type(input) == "number" then
                    value = math.clamp(input, min, max)
                else
                    local pct = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    value = math.floor(min + ((max - min) * pct))
                end
                local pct = (value - min) / (max - min)
                Levi.Flags[flag] = value
                valLbl.Text = tostring(value)
                
                util.tween(fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05)
                util.tween(knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.05)
                cb(value)
            end
            
            sldr.InputBegan:Connect(function(inp) 
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then 
                    dragging = true; update(inp) 
                end 
            end)
            UserInputService.InputEnded:Connect(function(inp) 
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then 
                    dragging = false 
                end 
            end)
            UserInputService.InputChanged:Connect(function(inp) 
                if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then 
                    update(inp) 
                end 
            end)
            
            Levi.Registry[flag] = update
            cb(default)
        end

        function TabElements:CreateDropdown(options)
            local title = options.Title or "Dropdown"
            local flag = options.Flag or title
            local desc = options.Description
            local list = options.Options or {}
            local multi = options.Multi or false
            local default = options.Default or (multi and {} or nil)
            local cb = options.Callback or function() end
            
            local h = desc and (layout.ElementHeight + 12) or layout.ElementHeight
            local isExpanded = false
            Levi.Flags[flag] = default
            
            local container = util.create("Frame", {
                Parent = page, Size = UDim2.new(0.92, 0, 0, h),
                BackgroundColor3 = Levi.Theme.Element, ClipsDescendants = true
            })
            util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = container})
            util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = container})
            
            local trigger = util.create("TextButton", {
                Parent = container, Size = UDim2.new(1, 0, 0, h),
                BackgroundTransparency = 1, Text = "", AutoButtonColor = false
            })
            
            local textFrame = util.create("Frame", {
                Parent = trigger, Position = UDim2.new(0, 16, 0, 0),
                Size = UDim2.new(1, -70, 1, 0), BackgroundTransparency = 1
            })
            util.create("UIListLayout", {
                Parent = textFrame, SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 1)
            })
            
            local titleLbl = util.create("TextLabel", {
                Parent = textFrame, Size = UDim2.new(1, 0, 0, 16),
                Text = "", RichText = true, Font = Enum.Font.GothamMedium,
                TextSize = layout.ElementSize, TextColor3 = Levi.Theme.Text,
                BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            if desc then
                util.create("TextLabel", {
                    Parent = textFrame, Size = UDim2.new(1, 0, 0, 14), Text = desc,
                    Font = Enum.Font.Gotham, TextSize = layout.ElementSize - 2,
                    TextColor3 = Levi.Theme.Muted, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
                })
            end
            
            local arrow = util.create("TextLabel", {
                Parent = trigger, Position = UDim2.new(1, -30, 0, 0),
                Size = UDim2.new(0, 16, 1, 0), Text = "▼", Font = Enum.Font.GothamMedium,
                TextSize = 10, TextColor3 = Levi.Theme.Muted, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local itemsList = util.create("Frame", {
                Parent = container, Position = UDim2.new(0, 0, 0, h),
                Size = UDim2.new(1, 0, 1, -h), BackgroundTransparency = 1
            })
            local itemsLayout = util.create("UIListLayout", {
                Parent = itemsList, Padding = UDim.new(0, 2), HorizontalAlignment = Enum.HorizontalAlignment.Center
            })
            util.create("UIPadding", {Parent = itemsList, PaddingTop = UDim.new(0, 4)})
            
            local function updateTitle()
                local val = Levi.Flags[flag]
                local display = "None"
                
                if multi then
                    if type(val) == "table" and #val > 0 then
                        display = #val > 2 and (#val .. " Selected") or table.concat(val, ", ")
                    end
                else
                    if val ~= nil and val ~= "" then display = tostring(val) end
                end
                titleLbl.Text = title .. ": <font color='#6366f1'>" .. display .. "</font>"
            end
            
            local function populate()
                for _, opt in ipairs(itemsList:GetChildren()) do
                    if opt:IsA("TextButton") then opt:Destroy() end
                end
                
                for _, item in ipairs(list) do
                    local active = false
                    if multi then
                        active = table.find(Levi.Flags[flag], item) ~= nil
                    else
                        active = Levi.Flags[flag] == item
                    end
                    
                    local btn = util.create("TextButton", {
                        Parent = itemsList, Size = UDim2.new(0.95, 0, 0, layout.ElementHeight - 8),
                        BackgroundColor3 = active and Levi.Theme.Accent or Color3.fromRGB(24, 24, 30),
                        Text = "", AutoButtonColor = false
                    })
                    util.create("UICorner", {CornerRadius = UDim.new(0, 4), Parent = btn})
                    
                    util.create("TextLabel", {
                        Parent = btn, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -24, 1, 0),
                        Text = tostring(item), Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize - 1,
                        TextColor3 = Levi.Theme.Text, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    btn.MouseEnter:Connect(function()
                        local isActive = multi and table.find(Levi.Flags[flag], item) or (Levi.Flags[flag] == item)
                        if not isActive then util.tween(btn, {BackgroundColor3 = Levi.Theme.Hover}, 0.1) end
                    end)
                    btn.MouseLeave:Connect(function()
                        local isActive = multi and table.find(Levi.Flags[flag], item) or (Levi.Flags[flag] == item)
                        if not isActive then util.tween(btn, {BackgroundColor3 = Color3.fromRGB(24, 24, 30)}, 0.1) end
                    end)
                    
                    btn.MouseButton1Click:Connect(function()
                        if multi then
                            local idx = table.find(Levi.Flags[flag], item)
                            if idx then table.remove(Levi.Flags[flag], idx) else table.insert(Levi.Flags[flag], item) end
                        else
                            Levi.Flags[flag] = item
                            isExpanded = false
                            util.tween(container, {Size = UDim2.new(0.92, 0, 0, h)})
                            arrow.Text = "▼"
                        end
                        updateTitle()
                        cb(Levi.Flags[flag])
                        populate()
                    end)
                end
            end
            
            trigger.MouseButton1Click:Connect(function()
                isExpanded = not isExpanded
                local targetH = isExpanded and (h + itemsLayout.AbsoluteContentSize.Y + 8) or h
                util.tween(container, {Size = UDim2.new(0.92, 0, 0, targetH)})
                arrow.Text = isExpanded and "▲" or "▼"
            end)
            
            local function updateState(val)
                Levi.Flags[flag] = val or (multi and {} or nil)
                updateTitle()
                populate()
                cb(Levi.Flags[flag])
            end
            
            Levi.Registry[flag] = updateState
            updateTitle()
            populate()
        end

        function TabElements:CreateTextbox(options)
            local title = options.Title or "Textbox"
            local flag = options.Flag or title
            local desc = options.Description
            local default = options.Default or ""
            local cb = options.Callback or function() end
            
            local h = desc and (layout.ElementHeight + 12) or layout.ElementHeight
            local boxW = isMobile and 110 or 160
            Levi.Flags[flag] = default
            
            local tbFrame = util.create("Frame", {
                Parent = page, Size = UDim2.new(0.92, 0, 0, h), BackgroundColor3 = Levi.Theme.Element
            })
            util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = tbFrame})
            local strk = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = tbFrame})
            
            local textFrame = util.create("Frame", {
                Parent = tbFrame, Position = UDim2.new(0, 16, 0, 0),
                Size = UDim2.new(1, -(boxW + 40), 1, 0), BackgroundTransparency = 1
            })
            util.create("UIListLayout", {
                Parent = textFrame, SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 1)
            })
            
            util.create("TextLabel", {
                Parent = textFrame, Size = UDim2.new(1, 0, 0, 16), Text = title,
                Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize,
                TextColor3 = Levi.Theme.Text, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            if desc then
                util.create("TextLabel", {
                    Parent = textFrame, Size = UDim2.new(1, 0, 0, 14), Text = desc,
                    Font = Enum.Font.Gotham, TextSize = layout.ElementSize - 2,
                    TextColor3 = Levi.Theme.Muted, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
                })
            end
            
            local boxContainer = util.create("Frame", {
                Parent = tbFrame, AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -16, 0.5, 0), Size = UDim2.new(0, boxW, 0, 28),
                BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            })
            util.create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = boxContainer})
            local boxStrk = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = boxContainer})
            
            local input = util.create("TextBox", {
                Parent = boxContainer, Size = UDim2.new(1, -16, 1, 0), Position = UDim2.new(0, 8, 0, 0),
                Text = default, PlaceholderText = "Enter...", PlaceholderColor3 = Color3.fromRGB(100, 100, 115),
                TextColor3 = Levi.Theme.Text, Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize - 1,
                BackgroundTransparency = 1, ClearTextOnFocus = false, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            input.Focused:Connect(function()
                util.tween(boxStrk, {Color = Levi.Theme.Accent})
                util.tween(boxContainer, {BackgroundColor3 = Color3.fromRGB(16, 16, 20)})
            end)
            
            input.FocusLost:Connect(function(enter)
                util.tween(boxStrk, {Color = Levi.Theme.Outline})
                util.tween(boxContainer, {BackgroundColor3 = Color3.fromRGB(22, 22, 28)})
                Levi.Flags[flag] = input.Text
                cb(input.Text, enter)
            end)
            
            local function updateState(val)
                Levi.Flags[flag] = val or ""
                input.Text = val or ""
                cb(val or "", false)
            end
            Levi.Registry[flag] = updateState
            cb(default, false)
        end
        
        function TabElements:CreateKeybind(options)
            local title = options.Title or "Keybind"
            local flag = options.Flag or title
            local default = options.Default or Enum.KeyCode.Unknown
            local cb = options.Callback or function() end
            
            Levi.Flags[flag] = default
            
            local kb = util.create("TextButton", {
                Parent = page, Size = UDim2.new(0.92, 0, 0, layout.ElementHeight),
                BackgroundColor3 = Levi.Theme.Element, Text = "", AutoButtonColor = false
            })
            util.create("UICorner", {CornerRadius = Levi.Theme.Corner, Parent = kb})
            local strk = util.create("UIStroke", {Color = Levi.Theme.Outline, Thickness = 1, Parent = kb})
            
            util.create("TextLabel", {
                Parent = kb, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(0.5, 0, 1, 0),
                Text = title, Font = Enum.Font.GothamMedium, TextSize = layout.ElementSize,
                TextColor3 = Levi.Theme.Text, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local valLbl = util.create("TextLabel", {
                Parent = kb, Position = UDim2.new(0.5, -16, 0, 0), Size = UDim2.new(0.5, 0, 1, 0),
                Text = "[" .. (default.Name == "Unknown" and "None" or default.Name) .. "]",
                Font = Enum.Font.GothamBold, TextSize = layout.ElementSize - 1,
                TextColor3 = Levi.Theme.Accent, BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local listening = false
            kb.MouseEnter:Connect(function() util.tween(strk, {Color = Levi.Theme.Accent}) end)
            kb.MouseLeave:Connect(function() util.tween(strk, {Color = Levi.Theme.Outline}) end)
            
            kb.MouseButton1Click:Connect(function()
                listening = true
                valLbl.Text = "[...]"
            end)
            
            local inputConn
            inputConn = UserInputService.InputBegan:Connect(function(inp, gpe)
                if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                    listening = false
                    Levi.Flags[flag] = inp.KeyCode
                    valLbl.Text = "[" .. inp.KeyCode.Name .. "]"
                elseif not gpe and inp.KeyCode == Levi.Flags[flag] and Levi.Flags[flag] ~= Enum.KeyCode.Unknown then
                    cb()
                end
            end)
            table.insert(Levi.Connections, inputConn)
            
            local function updateState(key)
                Levi.Flags[flag] = key
                valLbl.Text = "[" .. (key.Name == "Unknown" and "None" or key.Name) .. "]"
            end
            Levi.Registry[flag] = updateState
        end

        return TabElements
    end
    
    return Window
end

return Levi
